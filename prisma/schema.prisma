// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Device {
  id           String      @id
  name         String?
  type         String?     // e.g., "Inverter", "SmartMeter"
  location     String?
  telemetries  Telemetry[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Telemetry {
  id        BigInt   @default(autoincrement())
  device    Device   @relation(fields: [deviceId], references: [id])
  deviceId  String
  timestamp DateTime @default(now())
  
  // Electrical metrics (Primary/Phase-1)
  voltage   Float?   // V
  current   Float?   // A
  power     Float?   // W
  energy    Float?   // kWh
  frequency Float?   // Hz
  
  // Per-Phase Voltages
  voltageL1 Float?
  voltageL2 Float?
  voltageL3 Float?
  
  // Per-Phase Currents
  currentL1 Float?
  currentL2 Float?
  currentL3 Float?
  
  // Per-Phase Power Factor
  pfL1      Float?
  pfL2      Float?
  pfL3      Float?
  pfSystem  Float?
  
  // Per-Phase Power (kW)
  kwL1      Float?
  kwL2      Float?
  kwL3      Float?
  
  // Apparent/Reactive
  kva       Float?
  kvar      Float?
  
  // THD
  thdVL1    Float?
  thdVL2    Float?
  thdVL3    Float?

  // Environment/Status
  temp      Float?   // Celsius
  status    Int?     // Status code
  
  @@id([id, timestamp])
  @@index([deviceId, timestamp(sort: Desc)])
}
